{
  "data": {
    "allowed_chars": "!'(),.:;? \\-abcdefghijklmnopqrstuvwxyz",
    "batch_size": 4,
    "csv_test": "libritts-test.csv",
    "csv_train": "libritts-train.csv",
    "csv_val": "libritts-val.csv",
    "dataset_dir": "./LibriTTS",
    "end_token": "^",
    "expand_abbreviations": true,
    "num_mels": 80,
    "num_workers": 2,
    "sample_rate": 22050,
    "silence": 0,
    "trim": true,
    "trim_frame_length": 1024,
    "trim_top_db": 40
  },
  "model": {
    "att_dim": 128,
    "att_rnn_dim": 1024,
    "bert_model_name": "bert-base-uncased",
    "dropout": 0.5,
    "encoded_dim": 512,
    "encoder_kernel_size": 5,
    "gst_enabled": true,
    "hubert_checkpoint_path": null,
    "hubert_model_name": "facebook/hubert-base-ls960",
    "learning_rate": 0.0001,
    "num_chars": 39,
    "num_mels": 80,
    "postnet_dim": 512,
    "prenet_dim": 256,
    "rl_entropy_coef": 0.01,
    "rl_temperature": 1,
    "rnn_hidden_dim": 1024,
    "save_audio_dir": null,
    "save_audio_every_n_steps": 100,
    "speaker_count": 1,
    "speaker_tokens_enabled": false,
    "teacher_forcing_dropout": 0,
    "use_bert_gst": true,
    "use_rl_training": true,
    "use_vocoder": true,
    "vocoder_checkpoint_dir": null
  },
  "optimizer": {
    "class_path": "torch.optim.Adam",
    "init_args": {
      "lr": 0.0001
    }
  },
  "trainer": {
    "accelerator": "gpu",
    "callbacks": [
      {
        "class_path": "lightning.pytorch.callbacks.EarlyStopping",
        "init_args": {
          "mode": "min",
          "monitor": "val_loss",
          "patience": 10
        }
      },
      {
        "class_path": "lightning.pytorch.callbacks.ModelCheckpoint",
        "init_args": {
          "filename": "checkpoint-{epoch}-{step}",
          "mode": "min",
          "monitor": "val_loss",
          "save_last": true,
          "save_top_k": 3
        }
      }
    ],
    "devices": 1,
    "logger": {
      "class_path": "lightning.pytorch.loggers.TensorBoardLogger",
      "init_args": {
        "default_hp_metric": false,
        "name": "tts_rl",
        "save_dir": "lightning_logs"
      }
    },
    "log_every_n_steps": 10,
    "max_epochs": 100,
    "precision": "16-mixed"
  }
}
